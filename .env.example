# ─── Clinical Data Intelligence — Environment Variables ────────────
# You don't need this file to run. Just run `docker compose up` and
# the terminal will ask you for the required keys interactively.
#
# This file is only needed if you want to pre-configure values or
# run the app without interactive prompts (e.g., Hugging Face Spaces).

# ─── Database ────────────────────────────────────────────────────
# For docker-compose: these are overridden automatically.
# For standalone: set to your external Postgres.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=clinical_db
DB_USER=postgres
DB_PASS=postgres

# ─── AI Provider ─────────────────────────────────────────────────
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=

# ─── Auth (GitHub OAuth) ─────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
JWT_SECRET=
FRONTEND_URL=http://localhost:8000

# ─── Application ─────────────────────────────────────────────────
ENV=local
DEBUG=true

# ─── Langfuse Observability (optional) ────────────────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
